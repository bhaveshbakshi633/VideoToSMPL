{
  "name": "videotosmpl-web",
  "version": "0.1.0",
  "private": true,
  "description": "VideoToSMPL landing page + docs, static-exported to GitHub Pages.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:pages": "NEXT_BUILD_TARGET=pages next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .next out"
  },
  "dependencies": {
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "shiki": "^4.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
